<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_reschedule_wizard_form" model="ir.ui.view">
        <field name="name">clinic.reschedule.wizard.form</field>
        <field name="model">clinic.reschedule.wizard</field>
        <field name="arch" type="xml">
            <form string="Reschedule Appointment">
                <sheet>
                    <group>
                        <field name="appointment_id"/>
                        <field name="new_date"/>
                        <field name="new_doctor_id"/>
                        <field name="reason"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirm Reschedule" class="btn-primary" type="object" name="action_confirm_reschedule"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_clinic_reschedule_wizard" model="ir.actions.act_window">
        <field name="name">Reschedule Appointment</field>
        <field name="res_model">clinic.reschedule.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_clinic_reschedule_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
