<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
            <record id="ir_cron_auto_cancel_unconfirmed_appointements" model="ir.cron">
                <field name="name">Auto-cancel unconfirmed appointments</field>
                <field name="model_id" ref="model_clinic_appointment"/>
                <field name="state">code</field>
                <field name="code">model.auto_cancel_unconfirmed()</field>
                <field name="interval_number">1</field>
                <field name="interval_type">days</field>
                <field name="active" eval="True"/>
                <field name="numbercall">-1</field> <!-- -1 means this will repeat indefinitely -->
            <!-- Sets the very first execution to begin immediately when the module installs -->
            <field name="nextcall" eval="DateTime.now().strftime('%Y-%m-%d %H:%M:%S')"/>
            </record>
    </data>
</odoo>